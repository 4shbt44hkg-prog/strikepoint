{
  "name": "strikepoint",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts --port 8081",
    "build": "vite build",
    "start": "tsx src/server/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "three": "^0.185.1",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/three": "^0.185.0",
    "@types/ws": "^8.5.12",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
